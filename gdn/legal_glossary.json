    {"id":"G048","en":"Attorney of Record","es":"Abogado Registrado","zh":"登记律师","vi":"Luật Sư Đại Diện","ko":"기록 변호사","ar":"محامي مسجل","ht":"Avoka Anrejistre","pt":"Advogado Registrado","ru":"Зарегистрированный адвокат","tl":"Attorney of Record","so":"Qareenka Diiwaangeliyo","ti":"ጠበቓ ናይ ሰነድ","am":"የመዝገብ ጠበቃ","definition_en":"The lawyer officially designated to represent a party in a case."},
    {"id":"G049","en":"Guardian ad Litem","es":"Tutor ad Litem","zh":"诉讼监护人","vi":"Người Giám Hộ Vụ Kiện","ko":"소송후견인","ar":"وصي الدعوى","ht":"Gadyen ad Litem","pt":"Tutor ad Litem","ru":"Опекун ad litem","tl":"Guardian ad Litem","so":"Mas'uulka Dacwadda","ti":"ሓላዊ ንክሲ","am":"ለክስ ሞግዚት","definition_en":"A court-appointed person who represents a child's best interests in legal proceedings."},
    {"id":"G050","en":"Minor's Counsel","es":"Abogado del Menor","zh":"未成年人律师","vi":"Luật Sư Trẻ Em","ko":"미성년자 변호사","ar":"محامي القاصر","ht":"Avoka Minè","pt":"Advogado do Menor","ru":"Адвокат несовершеннолетнего","tl":"Abogado ng Minor","so":"Qareenka Yar-yar","ti":"ጠበቓ ትሕቲ ዕድመ","am":"የአካለ መጠን ያልደረሰ ጠበቃ","definition_en":"An attorney appointed by the court to represent the interests of a child."},
    {"id":"G051","en":"Move-Away Request","es":"Solicitud de Traslado","zh":"搬迁请求","vi":"Yêu Cầu Di Chuyển","ko":"이주 요청","ar":"طلب انتقال","ht":"Demann Deplase","pt":"Pedido de Mudança","ru":"Запрос на переезд","tl":"Kahilingan ng Paglipat","so":"Codsiga Guuritaanka","ti":"ሕቶ ምግዓዝ","am":"የመዘዋወር ጥያቄ","definition_en":"A request to relocate with a child to a different geographic area."},
    {"id":"G052","en":"Wage Assignment","es":"Asignación de Salario","zh":"工资扣除","vi":"Phân Bổ Lương","ko":"임금 배정","ar":"تخصيص الراتب","ht":"Distribisyon Salè","pt":"Penhora Salarial","ru":"Удержание из зарплаты","tl":"Wage Assignment","so":"Qorsheynta Mushaharka","ti":"ናይ ደሞዝ ምድላው","am":"የደሞዝ ሹመት","definition_en":"A court order directing an employer to deduct support payments from wages."},
    {"id":"G053","en":"Arrears","es":"Atrasos","zh":"欠款","vi":"Nợ Tồn Đọng","ko":"체납금","ar":"متأخرات","ht":"Aryere","pt":"Atrasos","ru":"Задолженность","tl":"Arrears","so":"Lacag-celinta","ti":"ናይ ድሕሪት ዕዳ","am":"ውዝፍ","definition_en":"Unpaid amounts of support that are past due."},
    {"id":"G054","en":"Quitclaim Deed","es":"Escritura de Renuncia","zh":"放弃权利契约","vi":"Giấy Từ Bỏ Quyền","ko":"권리포기증서","ar":"سند تنازل","ht":"Ak de Renonsyasyon","pt":"Escritura de Renúncia","ru":"Акт об отказе от прав","tl":"Quitclaim Deed","so":"Qalab-ka-tagidda","ti":"ናይ ምግዳፍ ሰነድ","am":"የመብት ማስተላለፍ","definition_en":"A document transferring property interest from one person to another without guarantees."},
    {"id":"G055","en":"Qualified Domestic Relations Order","es":"Orden Calificada de Relaciones Domésticas","zh":"合格家庭关系令","vi":"Lệnh Quan Hệ Gia Đình Hợp Lệ","ko":"적격 가사관계 명령","ar":"أمر العلاقات الأسرية المؤهل","ht":"Lòd Relasyon Domestik Kalifye","pt":"Ordem Qualificada de Relações Domésticas","ru":"Квалифицированный приказ о семейных отношениях","tl":"Qualified Domestic Relations Order","so":"Amarka Xiriirka Guriga ee Habboon","ti":"ብቁ ናይ ስድራቤት ዝምድና ትእዛዝ","am":"ብቁ የቤተሰብ ግንኙነት ትዕዛዝ","definition_en":"A court order dividing retirement benefits between spouses (QDRO)."},
    {"id":"G056","en":"Bifurcation","es":"Bifurcación","zh":"分案处理","vi":"Tách Vụ Kiện","ko":"분리","ar":"تقسيم","ht":"Bifourkasyon","pt":"Bifurcação","ru":"Разделение","tl":"Bifurcation","so":"Laba-qaybsi","ti":"ምፍላይ","am":"ማብቃት","definition_en":"Separating the divorce into two parts — ending the marriage while other issues are still pending."},
